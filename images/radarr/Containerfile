FROM registry.access.redhat.com/ubi9/ubi@sha256:46d19c10caf9888e8a01131283eaaf50c7f5d4eddab02cd92a66f8adf2e15407 AS builder

# renovate: datasource=custom.servarr depName=radarr versioning=loose registryUrl=https://radarr.servarr.com/v1/update/master/changes?runtime=netcore&os=linux&arch=x64
ARG RADARR_VERSION=6.2.1.10461
ARG RADARR_SHA256=4cae05c28b418d17d3f4cb9bc9ddc9d3f536122a9237d67aecd7afb751e52f7e

RUN mkdir -p /opt/radarr /config \
    && curl -fsSL \
        "https://github.com/Radarr/Radarr/releases/download/v${RADARR_VERSION}/Radarr.master.${RADARR_VERSION}.linux-core-x64.tar.gz" \
        -o /tmp/radarr.tar.gz \
    && echo "${RADARR_SHA256}  /tmp/radarr.tar.gz" | sha256sum -c - \
    && tar -xzf /tmp/radarr.tar.gz -C /opt/radarr --strip-components=1 \
    && rm -f /tmp/radarr.tar.gz \
    && rm -rf /opt/radarr/Radarr.Update \
    && find /opt/radarr -name '*.pdb' -delete

FROM registry.access.redhat.com/hi/dotnet-runtime:8.0@sha256:02d697873b55d26c536cc780baf8adc7f78698a59683413e4d2354c40b714432

ARG RADARR_VERSION=6.2.1.10461

LABEL org.opencontainers.image.source="https://github.com/major/container-images" \
      org.opencontainers.image.title="radarr" \
      org.opencontainers.image.version="${RADARR_VERSION}" \
      org.opencontainers.image.base.name="registry.access.redhat.com/hi/dotnet-runtime:8.0"

COPY --from=builder --chown=1026:100 /opt/radarr /opt/radarr
COPY --from=builder --chown=1026:100 /config /config
COPY --from=builder /usr/lib64/libsqlite3.so.0* /usr/lib64/

ENV XDG_CONFIG_HOME=/config

USER 1026:100
VOLUME ["/config"]
EXPOSE 7878

ENTRYPOINT ["/opt/radarr/Radarr", "-nobrowser", "-data=/config"]
